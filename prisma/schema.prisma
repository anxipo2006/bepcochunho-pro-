generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  CLIENT
}

enum MenuCategory {
  MAN
  CHAY
  NUOC
  THEM
}

enum OrderStatus {
  PENDING
  CONFIRMED
  DELIVERED
  CANCELLED
}

enum InvoiceStatus {
  UNPAID
  PAID
}

enum ConsultationStatus {
  NEW
  CONTACTED
  CLOSED
}

model User {
  id          String  @id @default(cuid())
  companyName String
  email       String  @unique
  password    String
  role        Role    @default(CLIENT)
  phone       String
  address     String?
  deliveryTimeRequest String? @map("delivery_time_request")
  isApproved  Boolean @default(false)
  debtBalance Decimal @default(0) @db.Decimal(12, 2)

  orders   Order[]
  invoices Invoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MenuItem {
  id          String       @id @default(cuid())
  name        String       @unique
  category    MenuCategory
  price       Decimal      @default(35000) @db.Decimal(12, 2)
  imageUrl    String?      @map("image_url")
  isAvailable Boolean      @default(true)

  dailyMenus DailyMenuItem[]
  orderItems OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DailyMenu {
  id   String   @id @default(cuid())
  date DateTime @db.Date

  items DailyMenuItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([date])
}

model WeeklyMenu {
  id        String   @id @default(cuid())
  title     String
  startDate DateTime @db.Date
  endDate   DateTime @db.Date
  isActive  Boolean  @default(true)

  cells WeeklyMenuCell[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([startDate])
}

model WeeklyMenuCell {
  id           String @id @default(cuid())
  weeklyMenuId String
  group        String
  slot         String
  dayIndex     Int
  dishName     String @db.VarChar(255)
  note         String?

  weeklyMenu WeeklyMenu @relation(fields: [weeklyMenuId], references: [id], onDelete: Cascade)

  @@unique([weeklyMenuId, group, slot, dayIndex])
  @@index([weeklyMenuId, dayIndex])
}

model DailyMenuItem {
  id          String @id @default(cuid())
  dailyMenuId String
  menuItemId  String

  dailyMenu DailyMenu @relation(fields: [dailyMenuId], references: [id], onDelete: Cascade)
  menuItem  MenuItem  @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@unique([dailyMenuId, menuItemId])
}

model Order {
  id           String      @id @default(cuid())
  userId       String
  invoiceId    String?
  orderDate    DateTime    @default(now())
  deliveryDate DateTime    @db.Date
  note         String?
  totalAmount  Decimal     @db.Decimal(12, 2)
  status       OrderStatus @default(PENDING)

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoice    Invoice?    @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  orderItems OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrderItem {
  id         String  @id @default(cuid())
  orderId    String
  menuItemId String
  quantity   Int
  note       String?

  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Restrict)
}

model Invoice {
  id           String        @id @default(cuid())
  userId       String
  totalAmount  Decimal       @db.Decimal(12, 2)
  billingMonth String
  status       InvoiceStatus @default(UNPAID)
  paidAt       DateTime?

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, billingMonth])
}

model ConsultationLead {
  id               String             @id @default(cuid())
  companyName      String
  expectedQuantity String
  phone            String
  status           ConsultationStatus @default(NEW)
  note             String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
}
